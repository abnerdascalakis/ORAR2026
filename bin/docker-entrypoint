#!/bin/bash -e

if [ "${RAILS_ENV}" == "development" ]; then
  bundle check || bundle install
fi

if [[ ( "${1}" == "./bin/rails" || "${1}" == "bin/rails" || "${1}" == "rails" ) && ( "${2}" == "server" || "${2}" == "s" ) ]] ||
   [[ "${1}" == "./bin/thrust" && ( "${2}" == "./bin/rails" || "${2}" == "bin/rails" || "${2}" == "rails" ) && ( "${3}" == "server" || "${3}" == "s" ) ]]; then
  ./bin/rails db:prepare
fi

exec "${@}"
