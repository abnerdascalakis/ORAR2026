<footer class="site-footer mt-5">
  <div class="container py-5">
    <div class="row g-5">
      <div class="col-lg-5">
        <h5 class="fw-bold mb-3">Localização do evento</h5>

        <div class="rounded-4 overflow-hidden shadow-sm border footer-map-wrapper mb-3">
          <iframe
            title="Mapa com a localização do ORAR 2026 em Porto Velho"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3943.3334081126945!2d-63.90769462445732!3d-8.754667189370451!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x92325cd1359d4829%3A0x182b7dab91ba239e!2sIASD%20Central%20de%20Porto%20Velho!5e0!3m2!1spt-BR!2sbr!4v1777500337981!5m2!1spt-BR!2sbr"
            class="footer-map-iframe"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>

        <ul class="list-unstyled footer-location-list mb-0">
          <li class="d-flex gap-2 mb-2">
            <i class="bi bi-geo-alt-fill"></i>
            <span>Igreja Adventista Central de Porto Velho</span>
          </li>
          <li class="d-flex gap-2">
            <i class="bi bi-geo-alt-fill"></i>
            <span>Colégio Adventista de Porto Velho</span>
          </li>
        </ul>
      </div>

      <div class="col-lg-6 offset-lg-1">
        <div class="row">
          <div class="col-md-6 mb-4 mb-md-0">
            <h6 class="text-uppercase fw-bold small mb-4 tracking-wider">Navegação</h6>
            <ul class="list-unstyled footer-links font-medium">
              <li class="mb-2"><%= link_to "Home", root_path, class: "text-decoration-none" %></li>
              <li class="mb-2"><%= link_to "Roteiro ORAR", roteiro_orar_path, class: "text-decoration-none" %></li>
              <li class="mb-2"><%= link_to "Inscrições", inscricoes_path, class: "text-decoration-none" %></li>
            </ul>
          </div>

          <div class="col-md-6">
            <h6 class="text-uppercase fw-bold small mb-4 tracking-wider">Contato Oficial</h6>
            <ul class="list-unstyled footer-links">
              <li class="mb-3 d-flex align-items-center">
                <i class="bi bi-geo-alt me-2"></i>
                <span>Porto Velho - RO</span>
              </li>
              <li class="mb-2 d-flex align-items-center">
                <i class="bi bi-instagram me-2"></i>
                <a href="https://www.instagram.com/jovensadventistas_anraro?igsh=Njd2dWZ6cTZxZHBm" target="_blank" class="text-decoration-none">Instagram</a>
              </li>
              <li class="mb-2 d-flex align-items-center">
                <i class="bi bi-whatsapp me-2"></i>
                <a href="https://wa.me/..." target="_blank" class="text-decoration-none">WhatsApp</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <hr class="my-5 opacity-10">

    <div class="row align-items-center pb-3">
      <div class="col-md-6 text-center text-md-start">
        <small>
          © <%= Time.current.year %> <strong>ORAR 2026</strong>. 
          <span class="d-none d-sm-inline mx-2">|</span> 
         Desenvolvido por Abner Dascalakis.
        </small>
      </div>
      <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
        <small> criado pela organização e comunicação do evento.</small>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background:
      linear-gradient(90deg, rgba(249, 178, 51, 0.1), rgba(249, 178, 51, 0) 18%),
      linear-gradient(110deg, rgba(233, 30, 99, 0.18), rgba(233, 30, 99, 0) 42%),
