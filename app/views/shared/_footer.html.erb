  }

  .site-footer::after {
    background:
      radial-gradient(circle, rgba(0, 0, 0, 0.22) 1.2px, transparent 1.4px),
      radial-gradient(circle, rgba(255, 255, 255, 0.08) 1px, transparent 1.25px);
