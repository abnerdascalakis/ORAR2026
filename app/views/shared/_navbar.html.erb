<% user_email = current_user&.email.to_s %>
<% user_name = user_email.split("@").first.to_s.titleize %>

<nav class="navbar navbar-light orar-navbar navbar-expand-lg fixed-top border-bottom border-secondary-subtle shadow-sm" data-controller="navbar">
  <div class="container">
    <%= link_to root_path, class: "navbar-brand orar-navbar-brand d-flex align-items-center gap-2", "aria-label": "ORAR 2026" do %>
      <%= image_tag "/logoorar.png", alt: "", class: "orar-navbar-brand__logo" %>
    <% end %>

    <button class="navbar-toggler" type="button" aria-controls="orarNavbar" aria-expanded="false" aria-label="Alternar navegação" data-navbar-target="button" data-action="navbar#toggle">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="orarNavbar" data-navbar-target="menu">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fs-5">
        <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link", data: { action: "navbar#close" } %></li>
        <li class="nav-item"><%= link_to "Roteiro ORAR", roteiro_orar_path, class: "nav-link", data: { action: "navbar#close" } %></li>
        <li class="nav-item"><%= link_to "Inscrições", inscricoes_path, class: "nav-link", data: { action: "navbar#close" } %></li>
        <% if user_signed_in? %>
          <li class="nav-item dropdown ms-lg-auto">
            <a
              class="nav-link dropdown-toggle d-flex align-items-center"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              aria-label="<%= current_user.admin? ? "Voltar para o administrativo" : "Menu da conta" %>"
              title="<%= current_user.admin? ? "Voltar para o administrativo" : "Menu da conta" %>"
            >
              <i class="bi bi-person-circle fs-4"></i>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4 p-2" style="min-width: 260px;">
              <li class="px-3 py-2 border-bottom">
                <strong class="d-block text-dark"><%= user_name %></strong>
                <span class="small text-secondary"><%= user_email %></span>
              </li>

              <% if current_user.admin? %>
                <li>
                  <%= link_to admin_root_path, class: "dropdown-item rounded-3 py-2 mt-2" do %>
                    <i class="bi bi-shield-lock me-2"></i>Voltar para o administrativo
                  <% end %>
                </li>
              <% end %>

              <li>
                <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item rounded-3 py-2 text-danger" do %>
                  <i class="bi bi-box-arrow-right me-2"></i>Sair
                <% end %>
              </li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item ms-lg-auto">
            <%= link_to new_user_session_path, class: "nav-link", "aria-label": "Entrar" do %>
              <i class="bi bi-person-circle fs-4"></i>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
