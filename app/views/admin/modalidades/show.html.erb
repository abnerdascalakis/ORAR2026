<% content_for :title, "#{@modalidade.nome_exibicao} | Admin" %>

<% actions = capture do %>
  <%= link_to admin_modalidades_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-arrow-left-circle me-2"></i>Voltar
  <% end %>
  <% if @modalidade.coletiva? %>
    <%= link_to new_admin_modalidade_equipe_path(@modalidade), class: "btn btn-light shadow-sm" do %>
      <i class="bi bi-people-fill me-2"></i>Incluir equipe
    <% end %>
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: @modalidade.nome_exibicao,
  subtitle: @modalidade.individual? ? "Inscritos nesta modalidade individual." : "Equipes cadastradas para esta modalidade.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Modalidades", path: admin_modalidades_path },
    { label: @modalidade.nome_exibicao }
  ],
  actions: actions
} do %>

  <% if @modalidade.individual? %>
    <div class="row g-4 mb-4">
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3">
              <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
                <i class="bi bi-person-check fs-4"></i>
              </div>
              <div>
                <span class="text-secondary d-block">Inscritos</span>
                <strong class="h3 mb-0"><%= @pagy_inscricao_modalidades.count %></strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 rounded-4 shadow-sm">
      <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
        <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
          <div>
            <h2 class="h5 fw-bold mb-1">Inscritos em <%= @modalidade.nome_exibicao %></h2>
            <p class="text-secondary mb-0">Listagem dos participantes que escolheram esta modalidade.</p>
          </div>
          <span class="badge rounded-pill text-bg-primary"><%= @pagy_inscricao_modalidades.count %> inscrito(s)</span>
        </div>
      </div>

      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Pessoa</th>
                <th>Sexo</th>
                <th>Distrito</th>
              </tr>
            </thead>
            <tbody>
              <% @inscricao_modalidades.each do |inscricao_modalidade| %>
                <% inscricao = inscricao_modalidade.inscricao %>
                <tr>
                  <td class="ps-4">
                    <strong class="d-block"><%= inscricao.pessoa.nome %></strong>
                    <span class="text-secondary small"><%= inscricao.pessoa.telefone.presence || "Sem telefone" %></span>
                  </td>
                  <td><%= inscricao.pessoa.sexo.nome %></td>
                  <td>
                    <span class="badge rounded-pill text-bg-light border">
                      <i class="bi bi-geo-alt me-1"></i><%= inscricao.distrito.nome %>
                    </span>
                  </td>
                </tr>
              <% end %>

              <% if @inscricao_modalidades.empty? %>
                <tr>
                  <td colspan="3" class="text-center text-secondary py-5">
                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                    Nenhum inscrito nesta modalidade.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <% if @pagy_inscricao_modalidades.pages > 1 %>
          <div class="border-top px-4 py-3 d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
            <%== @pagy_inscricao_modalidades.info_tag %>
            <%== @pagy_inscricao_modalidades.series_nav(:bootstrap, aria_label: "Paginação de inscritos") %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="row g-4 mb-4">
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3">
              <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
                <i class="bi bi-shield-check fs-4"></i>
              </div>
              <div>
                <span class="text-secondary d-block">Equipes</span>
                <strong class="h3 mb-0"><%= @equipes.length %></strong>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3">
              <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
                <i class="bi bi-person-check fs-4"></i>
              </div>
              <div>
                <span class="text-secondary d-block">Membros em equipes</span>
                <strong class="h3 mb-0"><%= @equipes.sum { |equipe| equipe.membros_count.to_i } %></strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <% @equipes.each do |equipe| %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
            <div class="card-body p-4">
              <div class="d-flex align-items-start justify-content-between gap-3">
                <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
                  <i class="bi bi-people fs-4"></i>
                </div>
                <span class="badge rounded-pill text-bg-light border"><%= equipe.membros_count %> membro(s)</span>
              </div>

              <h2 class="h5 fw-bold mt-4 mb-1" style="color: #163a63;"><%= equipe.nome %></h2>
              <p class="text-secondary mb-2">Gerencie a formacao desta equipe.</p>
              <div class="mb-4">
                <span class="badge rounded-pill text-bg-light border">
                  <i class="bi bi-geo-alt me-1"></i>
                  <%= equipe.distrito&.nome || "Distrito nao informado" %>
                </span>
              </div>

              <div class="d-flex gap-2 flex-wrap">
                <%= link_to admin_modalidade_equipe_path(@modalidade, equipe), class: "btn btn-sm btn-primary" do %>
                  <i class="bi bi-people-fill me-1"></i>Gerenciar
                <% end %>
                <%= link_to edit_admin_modalidade_equipe_path(@modalidade, equipe), class: "btn btn-sm btn-outline-secondary" do %>
                  <i class="bi bi-pencil-square me-1"></i>Editar
                <% end %>
                <%= link_to admin_modalidade_equipe_path(@modalidade, equipe), data: { turbo_method: :delete, turbo_confirm: "Excluir esta equipe?" }, class: "btn btn-sm btn-outline-danger" do %>
                  <i class="bi bi-trash3 me-1"></i>Excluir
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @equipes.empty? %>
        <div class="col-12">
          <div class="card border-0 rounded-4 shadow-sm">
            <div class="card-body text-center text-secondary py-5">
              <i class="bi bi-people fs-1 d-block mb-3"></i>
              <h2 class="h5 text-dark fw-bold">Nenhuma equipe cadastrada</h2>
              <p class="mb-4">Crie a primeira equipe desta modalidade para comecar a adicionar membros.</p>
              <%= link_to new_admin_modalidade_equipe_path(@modalidade), class: "btn btn-primary" do %>
                <i class="bi bi-people-fill me-2"></i>Incluir equipe
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
