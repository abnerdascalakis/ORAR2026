<% content_for :title, "Modalidades | Admin" %>

<% actions = capture do %>
  <%= link_to admin_root_path, class: "btn btn-light shadow-sm" do %>
    <i class="bi bi-arrow-left me-2"></i>Voltar
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: "Modalidades",
  subtitle: "Escolha uma modalidade para cadastrar equipes e organizar os membros inscritos.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Modalidades" }
  ],
  actions: actions
} do %>

  <div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-grid-3x3-gap fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Modalidades</span>
              <strong class="h3 mb-0"><%= @modalidades.length %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-people fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Inscricoes</span>
              <strong class="h3 mb-0"><%= @modalidades.sum { |modalidade| modalidade.inscricoes_count.to_i } %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-shield-check fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Equipes</span>
              <strong class="h3 mb-0"><%= @modalidades.sum { |modalidade| modalidade.equipes_count.to_i } %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 rounded-4 shadow-sm">
    <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="h5 fw-bold mb-1">Lista de modalidades</h2>
          <p class="text-secondary mb-0">Abra uma modalidade para ver e criar equipes.</p>
        </div>
        <span class="badge rounded-pill text-bg-primary"><%= @modalidades.length %> itens</span>
      </div>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Modalidade</th>
              <th class="text-center">Inscritos</th>
              <th class="text-center">Equipes</th>
              <th class="text-end pe-4">Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% @modalidades.each do |modalidade| %>
              <tr>
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-3">
                    <div class="admin-card-icon rounded-3 d-inline-flex align-items-center justify-content-center">
                      <i class="bi bi-trophy"></i>
                    </div>
                    <div>
                      <strong class="d-block"><%= modalidade.nome %></strong>
                      <% if modalidade.limite.present? %>
                        <span class="text-secondary small">Limite por equipe: <%= modalidade.limite %> membros</span>
                      <% else %>
                        <span class="text-secondary small">Sem limite informado</span>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="text-center">
                  <span class="badge rounded-pill text-bg-light border"><%= modalidade.inscricoes_count %></span>
                </td>
                <td class="text-center">
                  <span class="badge rounded-pill text-bg-light border"><%= modalidade.equipes_count %></span>
                </td>
                <td class="text-end pe-4">
                  <%= link_to admin_modalidade_path(modalidade), class: "btn btn-sm btn-primary" do %>
                    <i class="bi bi-arrow-right-circle me-1"></i>Abrir
                  <% end %>
                </td>
              </tr>
            <% end %>

            <% if @modalidades.empty? %>
              <tr>
                <td colspan="4" class="text-center text-secondary py-5">
                  <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                  Nenhuma modalidade cadastrada.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
