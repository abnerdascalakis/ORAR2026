<%= render layout: "shared/admin_shell", locals: {
  title: "Dashboard",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Dashboard" }
  ],
  topbar_image: "esportes.png",
  topbar_image_position: "center 82%"
} do %>
  <div class="row g-4">
    <% [
      ["bi-trophy-fill", "Modalidades", "Gerencie as modalidades e equipes do evento.", admin_modalidades_path],
      ["bi-clipboard2-check", "Inscrições", "Consulte participantes inscritos por nome, distrito e sexo.", admin_inscricoes_path],
      ["bi-buildings", "Sociedades", "Gerencie sociedades vinculadas ao sistema.", admin_sociedades_path],
      ["bi-map", "Distritos", "Estruture os distritos que participam do ORAR.", nil]
    ].each do |icon, title, description, path| %>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card admin-module-card border-0 rounded-4 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="admin-module-icon rounded-4 d-inline-flex align-items-center justify-content-center mb-3">
              <i class="bi <%= icon %> fs-4"></i>
            </div>

            <h3 class="h5 fw-bold mb-2" style="color: #163a63;"><%= title %></h3>
            <p class="text-secondary mb-4"><%= description %></p>

            <% if path.present? %>
              <%= link_to path, class: "btn btn-sm btn-primary" do %>
                <i class="bi bi-folder2-open me-1"></i>Abrir
              <% end %>
            <% else %>
              <span class="badge rounded-pill" style="background-color: #d9e6f5; color: #163a63;">
                Em breve
              </span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
