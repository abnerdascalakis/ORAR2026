<% content_for :title, "Inscricoes | Admin" %>

<% actions = capture do %>
  <%= link_to admin_root_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-arrow-left-circle me-2"></i>Voltar
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: "Inscricoes",
  subtitle: "Consulte todas as inscricoes e filtre por pessoa, distrito ou sexo.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Inscricoes" }
  ],
  actions: actions
} do %>

  <div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-card-checklist fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Resultado</span>
              <strong class="h3 mb-0"><%= @pagy_inscricoes.count %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 rounded-4 shadow-sm mb-4">
    <div class="card-body p-4">
      <%= search_form_for @q, url: admin_inscricoes_path, method: :get, html: { class: "row g-3 align-items-end" } do |form| %>
        <div class="col-12 col-lg-4">
          <%= form.label :pessoa_nome_cont, "Nome da pessoa", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <%= form.search_field :pessoa_nome_cont, class: "form-control", placeholder: "Pesquisar nome" %>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <%= form.label :sociedade_distrito_id_eq, "Distrito", class: "form-label fw-semibold" %>
          <%= form.collection_select :sociedade_distrito_id_eq, Distrito.order(:nome), :id, :nome, { include_blank: "Todos" }, class: "form-select" %>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <%= form.label :pessoa_sexo_id_eq, "Sexo", class: "form-label fw-semibold" %>
          <%= form.collection_select :pessoa_sexo_id_eq, Sexo.order(:nome), :id, :nome, { include_blank: "Todos" }, class: "form-select" %>
        </div>

        <div class="col-12 col-lg-2">
          <div class="d-flex gap-2">
            <%= form.submit "Filtrar", class: "btn btn-primary flex-fill" %>
            <%= link_to admin_inscricoes_path, class: "btn btn-outline-secondary", title: "Limpar filtros" do %>
              <i class="bi bi-x-lg"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card border-0 rounded-4 shadow-sm">
    <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="h5 fw-bold mb-1">Todas as inscricoes</h2>
          <p class="text-secondary mb-0">Listagem somente para consulta administrativa.</p>
        </div>
        <span class="badge rounded-pill text-bg-primary"><%= @pagy_inscricoes.count %> registro(s)</span>
      </div>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Pessoa</th>
              <th>Sociedade</th>
              <th>Distrito</th>
              <th>Sexo</th>
              <th>Modalidades</th>
            </tr>
          </thead>
          <tbody>
            <% @inscricoes.each do |inscricao| %>
              <tr>
                <td class="ps-4">
                  <strong class="d-block"><%= inscricao.pessoa.nome %></strong>
                  <span class="text-secondary small"><%= inscricao.pessoa.telefone.presence || "Sem telefone" %></span>
                </td>
                <td><%= inscricao.sociedade.nome %></td>
                <td>
                  <span class="badge rounded-pill text-bg-light border">
                    <i class="bi bi-geo-alt me-1"></i><%= inscricao.sociedade.distrito.nome %>
                  </span>
                </td>
                <td><%= inscricao.pessoa.sexo.nome %></td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <% inscricao.modalidades.each do |modalidade| %>
                      <span class="badge rounded-pill text-bg-secondary"><%= modalidade.nome %></span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>

            <% if @inscricoes.empty? %>
              <tr>
                <td colspan="5" class="text-center text-secondary py-5">
                  <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                  Nenhuma inscricao encontrada.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy_inscricoes.pages > 1 %>
        <div class="border-top px-4 py-3 d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
          <%== @pagy_inscricoes.info_tag %>
          <%== @pagy_inscricoes.series_nav(:bootstrap, aria_label: "Paginação de inscrições") %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
