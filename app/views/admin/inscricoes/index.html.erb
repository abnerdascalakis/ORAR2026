<% content_for :title, "Inscrições | Admin" %>

<% actions = capture do %>
  <%= link_to admin_root_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-arrow-left-circle me-2"></i>Voltar
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: "Inscrições",
  subtitle: "Consulte todas as inscrições e filtre por pessoa, distrito ou sexo.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Inscrições" }
  ],
  actions: actions
} do %>

  <div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-clipboard2-check fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Resultado</span>
              <strong class="h3 mb-0"><%= @pagy_inscricoes.count %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 rounded-4 shadow-sm mb-4">
    <div class="card-body p-4">
      <%= search_form_for @q, url: admin_inscricoes_path, method: :get, html: { class: "row g-3 align-items-end" } do |form| %>
        <div class="col-12 col-lg-4">
          <%= form.label :pessoa_nome_cont, "Nome da pessoa", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <%= form.search_field :pessoa_nome_cont, class: "form-control", placeholder: "Pesquisar nome" %>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <%= form.label :distrito_id_eq, "Distrito", class: "form-label fw-semibold" %>
          <div class="position-relative" data-controller="distrito-select">
            <%= form.hidden_field :distrito_id_eq, data: { distrito_select_target: "input" } %>

            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-search"></i></span>
              <input
                type="text"
                class="form-control"
                placeholder="Pesquisar distrito"
                value="<%= @distrito_filtro&.nome %>"
                autocomplete="off"
                data-distrito-select-target="search"
                data-action="input->distrito-select#filter focus->distrito-select#show"
              >
              <button
                type="button"
                class="btn btn-outline-secondary"
                data-action="distrito-select#clear"
                title="Limpar distrito"
              >
                <i class="bi bi-x-lg"></i>
              </button>
            </div>

            <div class="admin-search-menu list-group shadow-sm d-none" data-distrito-select-target="menu">
              <% Distrito.order(:nome).each do |distrito| %>
                <button
                  type="button"
                  class="list-group-item list-group-item-action d-flex align-items-center gap-2"
                  data-distrito-select-target="option"
                  data-distrito-id="<%= distrito.id %>"
                  data-distrito-name="<%= distrito.nome %>"
                  data-action="distrito-select#select"
                >
                  <i class="bi bi-geo-alt text-primary"></i>
                  <span><%= distrito.nome %></span>
                </button>
              <% end %>

              <div class="list-group-item text-secondary d-none" data-distrito-select-target="empty">
                Nenhum distrito encontrado.
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <%= form.label :pessoa_sexo_id_eq, "Sexo", class: "form-label fw-semibold" %>
          <%= form.collection_select :pessoa_sexo_id_eq, Sexo.order(:nome), :id, :nome, { include_blank: "Todos" }, class: "form-select" %>
        </div>

        <div class="col-12 col-lg-2">
          <div class="d-flex gap-2">
            <%= form.submit "Filtrar", class: "btn btn-primary flex-fill" %>
            <%= link_to admin_inscricoes_path, class: "btn btn-outline-secondary", title: "Limpar filtros" do %>
              <i class="bi bi-x-lg"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card border-0 rounded-4 shadow-sm">
    <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="h5 fw-bold mb-1">Todas as inscrições</h2>
          <p class="text-secondary mb-0">Listagem somente para consulta administrativa.</p>
        </div>
        <span class="badge rounded-pill text-bg-primary"><%= @pagy_inscricoes.count %> registro(s)</span>
      </div>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 text-center" style="width: 1%;">Ações</th>
              <th class="ps-4">Pessoa</th>
              <th>Sexo</th>
              <th>Adventista</th>
              <th>Estado civil</th>
              <th>Distrito</th>
              <th>Modalidades</th>
            </tr>
          </thead>
          <tbody>
            <% @inscricoes.each do |inscricao| %>
              <tr>
                <td class="ps-4 text-center text-nowrap">
                  <div class="dropdown">
                    <button
                      type="button"
                      class="btn btn-sm btn-outline-secondary"
                      data-bs-toggle="dropdown"
                      data-bs-auto-close="true"
                      aria-expanded="false"
                      aria-label="Ações da inscrição"
                      title="Ações da inscrição"
                    >
                      <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3 p-2">
                      <li>
                        <%= link_to edit_admin_inscricao_path(inscricao), class: "dropdown-item rounded-2 d-flex align-items-center gap-2" do %>
                          <i class="bi bi-pencil-square"></i>
                          <span>Editar</span>
                        <% end %>
                      </li>
                      <li>
                        <%= link_to admin_inscricao_path(inscricao),
                          data: { turbo_method: :delete, turbo_confirm: "Excluir esta inscrição?" },
                          class: "dropdown-item rounded-2 d-flex align-items-center gap-2 text-danger" do %>
                          <i class="bi bi-trash3"></i>
                          <span>Excluir</span>
                        <% end %>
                      </li>
                    </ul>
                  </div>
                </td>
                <td class="ps-4">
                  <strong class="d-block"><%= inscricao.pessoa.nome %></strong>
                  <span class="text-secondary small"><%= inscricao.pessoa.telefone.presence || "Sem telefone" %></span>
                </td>
                <td><%= inscricao.pessoa.sexo.nome %></td>
                <td><%= inscricao.adventista_label %></td>
                <td><%= inscricao.estado_civil_label %></td>
                <td>
                  <span class="badge rounded-pill text-bg-light border">
                    <i class="bi bi-geo-alt me-1"></i><%= inscricao.distrito.nome %>
                  </span>
                </td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <% inscricao.modalidades.each do |modalidade| %>
                      <span class="badge rounded-pill text-bg-secondary"><%= modalidade.nome_exibicao %></span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>

            <% if @inscricoes.empty? %>
              <tr>
                <td colspan="7" class="text-center text-secondary py-5">
                  <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                  Nenhuma inscrição encontrada.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy_inscricoes.pages > 1 %>
        <div class="border-top px-4 py-3 d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
          <%== @pagy_inscricoes.info_tag %>
          <%== @pagy_inscricoes.series_nav(:bootstrap, aria_label: "Paginação de inscrições") %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
