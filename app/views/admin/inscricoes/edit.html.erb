<% content_for :title, "Editar inscrição | Admin" %>

<% actions = capture do %>
  <%= link_to admin_inscricoes_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-arrow-left-circle me-2"></i>Voltar
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: "Editar inscrição",
  subtitle: "Atualize os dados de #{@inscricao.pessoa.nome}.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Inscrições", path: admin_inscricoes_path },
    { label: @inscricao.pessoa.nome },
    { label: "Editar" }
  ],
  actions: actions
} do %>

  <div class="row justify-content-center">
    <div class="col-12 col-xl-9">
      <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-pencil-square fs-4"></i>
            </div>
            <div>
              <h2 class="h5 fw-bold mb-1">Dados da inscrição</h2>
              <p class="text-secondary mb-0">Edite a inscrição sem criar ou excluir registros pelo admin.</p>
            </div>
          </div>
        </div>

        <div class="card-body p-4">
          <%= render "admin/inscricoes/form" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
