<% content_for :title, "Nova sociedade | Admin" %>

<% actions = capture do %>
  <%= link_to admin_sociedades_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-arrow-left me-2"></i>Voltar
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: "Nova sociedade",
  subtitle: "Cadastre uma sociedade e vincule ao distrito correspondente.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Sociedades", path: admin_sociedades_path },
    { label: "Nova sociedade" }
  ],
  actions: actions
} do %>

  <div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-6">
      <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-plus-circle fs-4"></i>
            </div>
            <div>
              <h2 class="h5 fw-bold mb-1">Dados da sociedade</h2>
              <p class="text-secondary mb-0">Informe o nome e o distrito.</p>
            </div>
          </div>
        </div>

        <div class="card-body p-4">
          <%= render "admin/sociedades/form" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
