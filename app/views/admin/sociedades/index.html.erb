<% content_for :title, "Sociedades | Admin" %>

<% actions = capture do %>
  <%= link_to admin_root_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-arrow-left-circle me-2"></i>Voltar
  <% end %>
  <%= link_to new_admin_sociedade_path, class: "btn btn-light shadow-sm" do %>
    <i class="bi bi-building-add me-2"></i>Nova sociedade
  <% end %>
<% end %>

<%= render layout: "shared/admin_shell", locals: {
  title: "Sociedades",
  subtitle: "Gerencie as sociedades vinculadas aos distritos.",
  breadcrumbs: [
    { label: "Home", path: admin_root_path },
    { label: "Sociedades" }
  ],
  actions: actions
} do %>

  <div class="row g-4 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-people fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Sociedades</span>
              <strong class="h3 mb-0"><%= @sociedades.length %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
      <div class="card admin-data-card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3">
            <div class="admin-card-icon rounded-4 d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-geo-alt fs-4"></i>
            </div>
            <div>
              <span class="text-secondary d-block">Distritos na lista</span>
              <strong class="h3 mb-0"><%= @sociedades.map(&:distrito_id).uniq.length %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 rounded-4 shadow-sm">
    <div class="card-header bg-white border-0 rounded-top-4 px-4 pt-4 pb-0">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="h5 fw-bold mb-1">Lista de sociedades</h2>
          <p class="text-secondary mb-0">Pesquise por sociedade ou distrito.</p>
        </div>
        <span class="badge rounded-pill text-bg-primary"><%= @sociedades.length %> itens</span>
      </div>

      <%= search_form_for @q, url: admin_sociedades_path, method: :get, html: { class: "row g-3 align-items-end mt-2 mb-3" } do |form| %>
        <div class="col-12 col-lg-5">
          <%= form.label :nome_or_distrito_nome_cont, "Pesquisar", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <%= form.search_field :nome_or_distrito_nome_cont, class: "form-control", placeholder: "Nome da sociedade ou distrito" %>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
          <%= form.label :distrito_id_eq, "Distrito", class: "form-label fw-semibold" %>
          <%= form.collection_select :distrito_id_eq,
            @distritos,
            :id,
            :nome,
            { include_blank: "Todos" },
            class: "form-select" %>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
          <div class="d-flex gap-2">
            <%= form.submit "Filtrar", class: "btn btn-outline-primary flex-fill" %>
            <%= link_to admin_sociedades_path, class: "btn btn-outline-secondary", title: "Limpar filtros" do %>
              <i class="bi bi-x-lg"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Sociedade</th>
              <th>Distrito</th>
              <th class="text-end pe-4">Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% @sociedades.each do |sociedade| %>
              <tr>
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-3">
                    <div class="admin-card-icon rounded-3 d-inline-flex align-items-center justify-content-center">
                      <i class="bi bi-people"></i>
                    </div>
                    <strong class="d-block"><%= sociedade.nome %></strong>
                  </div>
                </td>
                <td>
                  <span class="badge rounded-pill text-bg-light border">
                    <i class="bi bi-geo-alt me-1"></i><%= sociedade.distrito.nome %>
                  </span>
                </td>
                <td class="text-end pe-4">
                  <div class="d-flex justify-content-end gap-2 flex-wrap">
                    <%= link_to admin_sociedade_path(sociedade), class: "btn btn-sm btn-primary" do %>
                      <i class="bi bi-box-arrow-up-right me-1"></i>Abrir
                    <% end %>
                    <%= link_to edit_admin_sociedade_path(sociedade), class: "btn btn-sm btn-outline-secondary" do %>
                      <i class="bi bi-pencil-square me-1"></i>Editar
                    <% end %>
                    <%= link_to admin_sociedade_path(sociedade), data: { turbo_method: :delete, turbo_confirm: "Excluir esta sociedade?" }, class: "btn btn-sm btn-outline-danger" do %>
                      <i class="bi bi-trash3 me-1"></i>Excluir
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>

            <% if @sociedades.empty? %>
              <tr>
                <td colspan="3" class="text-center text-secondary py-5">
                  <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                  Nenhuma sociedade cadastrada.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
