<% images = [
  {
    source: "abertura-1920.webp",
    srcset: [["abertura-768.webp", "768w"], ["abertura-1280.webp", "1280w"], ["abertura-1920.webp", "1920w"]]
  },
  {
    source: "investidura-1920.webp",
    srcset: [["investidura-768.webp", "768w"], ["investidura-1280.webp", "1280w"], ["investidura-1920.webp", "1920w"]]
  },
  {
    source: "humaita-1920.webp",
    srcset: [["humaita-768.webp", "768w"], ["humaita-1280.webp", "1280w"], ["humaita-1920.webp", "1920w"]]
  },
  {
    source: "setimus-1920.webp",
    srcset: [["setimus-768.webp", "768w"], ["setimus-1280.webp", "1280w"], ["setimus-1920.webp", "1920w"]]
  }
].select { |image| Rails.application.assets.load_path.find(image[:source]) } %>

<div id="orarCarousel" class="carousel slide carousel-fade orar-full-carousel" data-bs-ride="carousel" data-bs-interval="4500" data-bs-touch="true" data-bs-pause="false">
  <div class="carousel-inner">
    <% images.each_with_index do |image, index| %>
      <div class="carousel-item <%= "active" if index.zero? %>">
        <%= responsive_asset_picture(
          image[:source],
          alt: "ORAR 2026",
          sizes: "100vw",
          width: 1920,
          height: 1280,
          srcset: image[:srcset],
          img_class: "d-block w-100 orar-full-image",
          loading: (index.zero? ? "eager" : "lazy"),
          fetchpriority: (index.zero? ? "high" : "auto")
        ) %>
      </div>
    <% end %>
  </div>

  <div class="orar-carousel-caption text-center">
    <h1 class="mb-2">ORAR 2026</h1>
    <p class="mb-0">Olimpíada Regional Adventista de Rondônia</p>
  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#orarCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Anterior</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#orarCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Próxima</span>
  </button>
</div>

<style>
  .orar-full-carousel {
    width: 100%;
    height: min(760px, calc(100svh - var(--orar-navbar-height, 88px)));
    min-height: 520px;
    background: #0f0f0f;
    overflow: hidden;
    position: relative;
  }

  .orar-full-carousel .carousel-inner,
  .orar-full-carousel .carousel-item {
    height: 100%;
  }

  .orar-full-carousel .orar-imagem {
    height: 100%;
  }

  .orar-full-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
  }

  .orar-carousel-caption {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: min(90%, 760px);
    color: #fff;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.65);
    padding: 0 1rem;
  }

  .orar-carousel-caption h1 {
    font-size: clamp(2.1rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .orar-carousel-caption p {
    font-size: clamp(0.95rem, 1.7vw, 1.15rem);
    font-weight: 500;
    opacity: 0.96;
  }

  .orar-full-carousel .carousel-control-prev,
  .orar-full-carousel .carousel-control-next {
    width: 7%;
  }

  @media (max-width: 768px) {
    .orar-full-carousel {
      height: 56svh;
      min-height: 320px;
    }

    .orar-full-image {
      object-position: center;
    }

    .orar-carousel-caption {
      width: min(92%, 560px);
      padding: 0 0.75rem;
    }

    .orar-carousel-caption h1 {
      font-size: clamp(2rem, 9vw, 2.8rem);
      margin-bottom: 0.45rem !important;
    }

    .orar-carousel-caption p {
      font-size: clamp(0.95rem, 4vw, 1.1rem);
      line-height: 1.25;
    }
  }
</style>
