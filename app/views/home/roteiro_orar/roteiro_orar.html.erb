<% content_for :title, "Informações Gerais - ORAR 2026" %>

<main class="orar-docs-page py-5">
  <div class="container orar-docs-container">
    <header class="text-center mb-5">
      <p class="orar-section-kicker mb-2">Documentação</p>
      <h1 class="display-5 fw-semibold text-marinho mb-3">Informações Gerais</h1>
      <p class="lead text-claro mb-0">Acesse a documentação completa do evento ORAR 2026.</p>
    </header>

    <div class="row g-4">
      <div class="col-12 col-lg-6">
        <article class="card orar-doc-card h-100 border-0 shadow-sm">
          <div class="card-body p-4 p-lg-5 d-flex flex-column">
            <span class="badge orar-doc-badge align-self-start mb-3">
              <i class="bi bi-file-earmark-pdf me-2" aria-hidden="true"></i>Documentação Oficial
            </span>
            <h2 class="h3 text-marinho mb-3">Boletim Informativo ORAR</h2>
            <p class="text-secondary mb-4">
              Acesse o boletim informativo completo com programação, horários, locais e demais orientações importantes do evento.
            </p>
            <div class="orar-doc-preview rounded-4 border mb-4">
              <i class="bi bi-file-earmark-pdf-fill" aria-hidden="true"></i>
              <span>Clique para visualizar ou baixar o PDF</span>
            </div>
            <div class="d-flex gap-2 mt-auto">
              <a href="/pdfs/informativoORAR.pdf" class="btn btn-outline-primary flex-fill" target="_blank" rel="noopener">
                <i class="bi bi-eye me-2" aria-hidden="true"></i>Visualizar PDF
              </a>
              <a href="/pdfs/informativoORAR.pdf" class="btn btn-marinho flex-fill" download>
                <i class="bi bi-download me-2" aria-hidden="true"></i>Baixar boletim
              </a>
            </div>
          </div>
        </article>
      </div>

      <div class="col-12 col-lg-6">
        <article class="card orar-doc-card h-100 border-0 shadow-sm">
          <div class="card-body p-4 p-lg-5 d-flex flex-column">
            <span class="badge orar-doc-badge align-self-start mb-3">
              <i class="bi bi-signpost-2 me-2" aria-hidden="true"></i>Guia Prático
            </span>
            <h2 class="h3 text-marinho mb-3">Roteiro do Evento</h2>
            <p class="text-secondary mb-4">
              Confira a sequência das atividades, intervalos e apresentações para se organizar melhor durante o ORAR 2026.
            </p>
            <div class="orar-doc-preview rounded-4 border mb-4">
              <i class="bi bi-file-earmark-pdf-fill" aria-hidden="true"></i>
              <span>Clique para visualizar ou baixar o PDF</span>
            </div>
            <div class="d-flex gap-2 mt-auto">
              <a href="/pdfs/roteiro.pdf" class="btn btn-outline-primary flex-fill" target="_blank" rel="noopener">
                <i class="bi bi-eye me-2" aria-hidden="true"></i>Visualizar PDF
              </a>
              <a href="/pdfs/roteiro.pdf" class="btn btn-marinho flex-fill" download>
                <i class="bi bi-download me-2" aria-hidden="true"></i>Baixar roteiro
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</main>

<style>
  .text-marinho {
    color: #163a63 !important;
  }

  .text-claro {
    color: #5e86b5 !important;
  }

  .btn-marinho {
    background: linear-gradient(135deg, #2e5f95 0%, #5e86b5 100%);
    border: 0;
    color: #fff;
  }

  .btn-marinho:hover,
  .btn-marinho:focus {
    background: linear-gradient(135deg, #163a63 0%, #2e5f95 100%);
    color: #fff;
  }

  .orar-docs-page {
    background:
      radial-gradient(circle at top, rgba(217, 230, 245, 0.7), transparent 45%),
      linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    min-height: calc(100vh - var(--orar-navbar-height));
  }

  .orar-docs-container {
    padding-top: calc(var(--orar-navbar-height) + 1rem);
  }

  .orar-doc-card {
    border-radius: 24px;
    box-shadow: 0 18px 40px rgba(28, 54, 84, 0.08);
  }

  .orar-doc-badge {
    background-color: #d9e6f5;
    color: #163a63;
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.6rem 0.9rem;
    text-transform: uppercase;
  }

  .orar-doc-preview {
    align-items: center;
    background: #f8f9fa;
    border-color: rgba(143, 175, 206, 0.55) !important;
    color: #6c757d;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: center;
    min-height: 148px;
    padding: 1.5rem;
    text-align: center;
  }

  .orar-doc-preview i {
    color: #163a63;
    font-size: 2rem;
  }

  @media (max-width: 575.98px) {
    .orar-docs-container {
      padding-top: calc(var(--orar-navbar-height) + 0.5rem);
    }
  }
</style>
