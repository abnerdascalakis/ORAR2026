<main>
  <section class="p-0">
    <div id="orarCarousel" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-inner">
        <div class="carousel-item active position-relative">
          <%= image_tag "abertura.jpeg", class: "d-block w-100 orar-hero-image", alt: "Abertura ORAR 2026" %>
          <div class="carousel-caption d-flex h-100 w-100 top-0 start-0 orar-hero-overlay">
            <div class="container my-auto text-center">
              <h1 class="display-3 fw-bold text-white">ORAR 2026</h1>
              <p class="lead text-white mb-0">Olimpíada Regional Adventista de Rondônia</p>
            </div>
          </div>
        </div>
        <div class="carousel-item position-relative">
          <%= image_tag "investidura.jpeg", class: "d-block w-100 orar-hero-image", alt: "Investidura ORAR 2026" %>
          <div class="carousel-caption d-flex h-100 w-100 top-0 start-0 orar-hero-overlay">
            <div class="container my-auto text-center">
              <h1 class="display-3 fw-bold text-white">ORAR 2026</h1>
              <p class="lead text-white mb-0">Olimpíada Regional Adventista de Rondônia</p>
            </div>
          </div>
        </div>
        <div class="carousel-item position-relative">
          <%= image_tag "humaita.jpeg", class: "d-block w-100 orar-hero-image", alt: "Humaitá ORAR 2026" %>
          <div class="carousel-caption d-flex h-100 w-100 top-0 start-0 orar-hero-overlay">
            <div class="container my-auto text-center">
              <h1 class="display-3 fw-bold text-white">ORAR 2026</h1>
              <p class="lead text-white mb-0">Olimpíada Regional Adventista de Rondônia</p>
            </div>
          </div>
        </div>
      </div>
      <button class="carousel-control-prev" type="button" data-bs-target="#orarCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Anterior</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#orarCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Próxima</span>
      </button>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="text-center mb-4">
        <h2 class="fw-bold mb-2">Fotos do Último ORAR</h2>
      </div>
      <div class="row g-4">
        <div class="col-md-6 col-lg-4"><%= image_tag "ulisses.jpeg", class: "img-fluid rounded shadow-sm w-100", alt: "Ulisses" %></div>
        <div class="col-md-6 col-lg-4"><%= image_tag "candeias.jpeg", class: "img-fluid rounded shadow-sm w-100", alt: "Candeias" %></div>
        <div class="col-md-6 col-lg-4"><%= image_tag "setimus.jpeg", class: "img-fluid rounded shadow-sm w-100", alt: "Setimus" %></div>
        <div class="col-md-6 col-lg-4"><%= image_tag "forjados.jpeg", class: "img-fluid rounded shadow-sm w-100", alt: "Forjados" %></div>
        <div class="col-md-6 col-lg-4"><%= image_tag "volei.jpeg", class: "img-fluid rounded shadow-sm w-100", alt: "Volei" %></div>
        <div class="col-md-6 col-lg-4"><%= image_tag "eldorado.jpeg", class: "img-fluid rounded shadow-sm w-100", alt: "Eldorado" %></div>
      </div>
    </div>
  </section>
</main>
