<% content_for :title, "Inscricao" %>

<main class="orar-inscricao-page py-5">
  <section class="container orar-inscricao-container">
    <div class="row justify-content-center">
      <div class="col-12 col-xl-10">
        <div class="orar-form-shell">
          <div class="row g-0">
            <div class="col-12 col-lg-4">
              <aside class="orar-form-sidebar h-100">
                <span class="orar-form-kicker">ORAR 2026</span>
                <h1 class="display-6 fw-semibold mb-3">Inscrição para o evento</h1>
                <p class="text-white-50 mb-4">
                  Preencha seus dados e escolha as modalidades em que vai participar, depois se inscreva no evento.
                </p>

                <div class="orar-side-card">
                  <p class="small text-uppercase fw-semibold mb-2">Etapas</p>
                  <ul class="list-unstyled mb-0 text-white-50">
                    <li class="mb-2">1. Inscrição das modalidades</li>
                    <li class="mb-2">2. Escolha das modalidades</li>
                    <li>3. Inscrição no evento</li>
                  </ul>
                </div>
              </aside>
            </div>

            <div class="col-12 col-lg-8">
              <div
                class="orar-form-panel"
                data-controller="multi-step-form"
                data-multi-step-form-initial-step-value="<%= @current_step %>"
                data-multi-step-form-step-count-value="3"
              >
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
                  <div>
                    <p class="orar-section-kicker mb-2">Formulário de inscrição</p>
                    <h2 class="h3 mb-1">Conclua sua participação no ORAR</h2>
                  </div>

                  <div class="orar-step-badge">
                    <span data-multi-step-form-target="stepLabel">Etapa 1 de 3</span>
                  </div>
                </div>

                <div class="orar-stepper mb-4" aria-label="Progresso do formulario">
                  <div class="progress orar-stepper-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" data-multi-step-form-target="progressBar" style="width: 33.33%;"></div>
                  </div>

                  <div class="orar-stepper-items mt-4">
                    <button
                      class="orar-stepper-item <%= @current_step.zero? ? "is-active" : "" %>"
                      type="button"
                      data-step-index="0"
                      data-multi-step-form-target="indicator"
                      data-action="multi-step-form#goToStep"
                    >
                      <span class="orar-stepper-circle">1</span>
                      <span>
                        <strong>Participante</strong>
                        <small>Dados principais</small>
                      </span>
                    </button>

                    <button
                      class="orar-stepper-item <%= @current_step == 1 ? "is-active" : "" %>"
                      type="button"
                      data-step-index="1"
                      data-multi-step-form-target="indicator"
                      data-action="multi-step-form#goToStep"
                    >
                      <span class="orar-stepper-circle">2</span>
                      <span>
                        <strong>Modalidades</strong>
                        <small>Escolha final</small>
                      </span>
                    </button>

                    <button
                      class="orar-stepper-item <%= @current_step == 2 ? "is-active" : "" %>"
                      type="button"
                      data-step-index="2"
                      data-multi-step-form-target="indicator"
                      data-action="multi-step-form#goToStep"
                    >
                      <span class="orar-stepper-circle">3</span>
                      <span>
                        <strong>Evento</strong>
                        <small>Inscrição geral</small>
                      </span>
                    </button>
                  </div>
                </div>

                <div class="alert alert-danger <%= @error_messages.any? ? "" : "d-none" %>" role="alert" data-multi-step-form-target="errorSummary">
                  Revise os campos obrigatorios destacados antes de continuar.
                </div>

                <% if @error_messages.any? %>
                  <div class="alert alert-danger" role="alert">
                    <strong>Nao foi possivel salvar a inscricao.</strong>
                    <ul class="mb-0 mt-2 ps-3">
                      <% @error_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <%= form_with url: inscricoes_path, scope: :inscricao, local: true, html: { class: "needs-validation", novalidate: true, data: { turbo: false, multi_step_form_target: "form", action: "submit->multi-step-form#submitForm" } } do %>
                  <section
                    class="orar-step-panel <%= @current_step.zero? ? "is-active" : "" %>"
                    data-step-index="0"
                    data-multi-step-form-target="step"
                  >
                    <div class="mb-4">
                      <h3 class="h4 mb-1">Dados do participante</h3>
                      <p class="text-secondary mb-0">Preencha as informações para gerar a inscricão de modalidades.</p>
                    </div>

                    <div class="row g-3">
                      <div class="col-12">
                        <%= label_tag "inscricao_nome", "Nome do participante *", class: "form-label" %>
                        <%= text_field_tag "inscricao[nome]", @form_data[:nome], class: "form-control", placeholder: "Ex.: Maria Silva", required: true, data: { multi_step_form_target: "field" } %>
                        <div class="invalid-feedback">Informe o nome do participante.</div>
                      </div>

                      <div class="col-12 col-md-6">
                        <%= label_tag "inscricao_telefone", "Telefone *", class: "form-label" %>
                        <%= telephone_field_tag "inscricao[telefone]",
                          @form_data[:telefone],
                          class: "form-control",
                          placeholder: "(69) 99999-9999",
                          required: true,
                          maxlength: 15,
                          minlength: 15,
                          pattern: "\\(\\d{2}\\) \\d{5}-\\d{4}",
                          title: "Use o formato (69) 99999-9999",
                          inputmode: "numeric",
                          data: {
                            multi_step_form_target: "field",
                            action: "input->multi-step-form#formatTelefone"
                          } %>
                        <div class="invalid-feedback">Informe o telefone no formato (69) 99999-9999.</div>
                      </div>

                      <div class="col-12 col-md-6">
                        <%= label_tag "inscricao_sexo_id", "Sexo *", class: "form-label" %>
                        <div class="orar-radio-grid">
                          <% @sexos.each do |sexo| %>
                            <label class="orar-radio-card">
                              <%= radio_button_tag "inscricao[sexo_id]",
                                sexo.id,
                                @form_data[:sexo_id].to_s == sexo.id.to_s,
                                id: "inscricao_sexo_id_#{sexo.id}",
                                class: "form-check-input",
                                required: true,
                                data: { multi_step_form_target: "field" } %>
                              <span><%= sexo.nome %></span>
                            </label>
                          <% end %>
                        </div>
                        <div class="invalid-feedback">Escolha uma opcao de sexo.</div>
                      </div>

                      <div class="col-12 col-md-6">
                        <%= label_tag "inscricao_adventista", "Adventista *", class: "form-label" %>
                        <div class="orar-radio-grid">
                          <label class="orar-radio-card">
                            <%= radio_button_tag "inscricao[adventista]",
                              "true",
                              @form_data[:adventista].to_s == "true",
                              id: "inscricao_adventista_true",
                              class: "form-check-input",
                              required: true,
                              data: { multi_step_form_target: "field" } %>
                            <span>Sim</span>
                          </label>

                          <label class="orar-radio-card">
                            <%= radio_button_tag "inscricao[adventista]",
                              "false",
                              @form_data[:adventista].to_s == "false",
                              id: "inscricao_adventista_false",
                              class: "form-check-input",
                              required: true,
                              data: { multi_step_form_target: "field" } %>
                            <span>Nao</span>
                          </label>
                        </div>
                        <div class="invalid-feedback">Informe se o participante e adventista.</div>
                      </div>

                      <div class="col-12 col-md-6">
                        <%= label_tag "inscricao_estado_civil", "Estado civil *", class: "form-label" %>
                        <div class="orar-radio-grid">
                          <% Inscricao::ESTADOS_CIVIS.each do |valor, label| %>
                            <label class="orar-radio-card">
                              <%= radio_button_tag "inscricao[estado_civil]",
                                valor,
                                @form_data[:estado_civil].to_s == valor,
                                id: "inscricao_estado_civil_#{valor}",
                                class: "form-check-input",
                                required: true,
                                data: { multi_step_form_target: "field" } %>
                              <span><%= label %></span>
                            </label>
                          <% end %>
                        </div>
                        <div class="invalid-feedback">Escolha um estado civil.</div>
                      </div>

                      <div class="col-12">
                        <div class="row g-3">
                          <div class="col-12 col-md-6">
                            <%= label_tag "inscricao_distrito_id", "Distrito *", class: "form-label" %>
                            <div class="position-relative" data-controller="distrito-select">
                              <%= hidden_field_tag "inscricao[distrito_id]",
                                @form_data[:distrito_id],
                                id: "inscricao_distrito_id",
                                data: {
                                  distrito_select_target: "input"
                                } %>

                              <div class="input-group orar-search-input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input
                                  type="text"
                                  class="form-control"
                                  placeholder="Pesquisar distrito"
                                  value="<%= @distritos.find { |distrito| distrito.id == @form_data[:distrito_id].to_i }&.nome %>"
                                  autocomplete="off"
                                  required
                                  data-multi-step-form-target="field"
                                  data-distrito-select-target="search"
                                  data-action="input->distrito-select#filter focus->distrito-select#show"
                                >
                                <button
                                  type="button"
                                  class="btn btn-outline-secondary orar-clear-input-btn"
                                  data-action="distrito-select#clear"
                                  title="Limpar distrito"
                                >
                                  <i class="bi bi-x-lg"></i>
                                </button>
                                <div class="invalid-feedback">Escolha um distrito da lista.</div>
                              </div>

                              <div class="admin-search-menu list-group shadow-sm d-none" data-distrito-select-target="menu">
                                <% @distritos.each do |distrito| %>
                                  <button
                                    type="button"
                                    class="list-group-item list-group-item-action d-flex align-items-center gap-2"
                                    data-distrito-select-target="option"
                                    data-distrito-id="<%= distrito.id %>"
                                    data-distrito-name="<%= distrito.nome %>"
                                    data-action="distrito-select#select"
                                  >
                                    <i class="bi bi-geo-alt text-primary"></i>
                                    <span><%= distrito.nome %></span>
                                  </button>
                                <% end %>

                                <div class="list-group-item text-secondary d-none" data-distrito-select-target="empty">
                                  Nenhum distrito encontrado.
                                </div>
                              </div>
                            </div>
                            <div class="form-text">Caso seu distrito não esteja na lista, selecione a opção "Outro".</div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                      <button type="button" class="btn btn-primary px-4" data-action="multi-step-form#nextStep">
                        Proximo
                      </button>
                    </div>
                  </section>

                  <section
                    class="orar-step-panel <%= @current_step == 1 ? "is-active" : "" %>"
                    data-step-index="1"
                    data-multi-step-form-target="step"
                    <%= "hidden" if @current_step.zero? %>
                  >
                    <div class="mb-4">
                      <h3 class="h4 mb-1">Modalidades</h3>
                      <p class="text-secondary mb-0">Escolha uma ou mais modalidades para concluir sua inscricão.</p>
                    </div>

                    <% if @modalidades.any? %>
                      <div class="mb-4">
                        <label class="form-label d-block">Modalidades *</label>
                        <div class="row g-3">
                          <% @modalidades.each do |modalidade| %>
                            <div class="col-12 col-md-6">
                              <label class="orar-option-card form-check">
                                <%= check_box_tag "inscricao[modalidade_ids][]", modalidade.id, @selected_modalidade_ids.include?(modalidade.id), id: "modalidade_#{modalidade.id}", class: "form-check-input", data: { multi_step_form_target: "modalidadeField" } %>
                                <span class="form-check-label">
                                  <strong class="d-block"><%= modalidade.nome_exibicao %></strong>
                                 
                                </span>
                              </label>
                            </div>
                          <% end %>
                        </div>

                        <div class="invalid-feedback d-block <%= @error_messages.include?("Selecione ao menos uma modalidade.") ? "" : "d-none" %>" data-multi-step-form-target="modalidadeError">
                          Selecione ao menos uma modalidade.
                        </div>
                      </div>
                    <% else %>
                      <div class="alert alert-warning mb-4" role="alert">
                        Nenhuma modalidade foi cadastrada ainda. Adicione modalidades no sistema para liberar as inscricoes.
                      </div>
                    <% end %>

                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mt-4">
                      <button type="button" class="btn btn-secondary px-4" data-action="multi-step-form#previousStep">
                        Voltar
                      </button>

                      <button type="button" class="btn btn-primary px-4" data-action="multi-step-form#nextStep" <%= "disabled" unless @modalidades.any? %>>
                        Próximo
                      </button>
                    </div>
                  </section>

                  <section
                    class="orar-step-panel <%= @current_step == 2 ? "is-active" : "" %>"
                    data-step-index="2"
                    data-multi-step-form-target="step"
                    <%= "hidden" unless @current_step == 2 %>
                  >
                    <div class="mb-4">
                      <h3 class="h4 mb-1">Inscrição no evento</h3>
                      <p class="text-secondary mb-0">Finalize também sua inscrição geral no evento antes de concluir.</p>
                    </div>

                    <div class="orar-event-link-card">
                      <div>
                        <p class="orar-section-kicker mb-2">Link do evento</p>
                        <h4 class="h5 mb-2">Inscrição geral ORAR 2026</h4>
                        <p class="text-secondary mb-0">Abra o formulário oficial do evento em uma nova aba.</p>
                      </div>

                      <%= button_tag "Abrir inscrição",
                        type: "submit",
                        name: "redirect_to_event",
                        value: "1",
                        class: "btn btn-outline-primary px-4" %>
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mt-4">
                      <button type="button" class="btn btn-secondary px-4" data-action="multi-step-form#previousStep">
                        Voltar
                      </button>
                    </div>
                  </section>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .orar-inscricao-page {
      background:
        radial-gradient(circle at top left, rgba(42, 87, 136, 0.16), transparent 30%),
        radial-gradient(circle at bottom right, rgba(222, 184, 135, 0.18), transparent 28%),
        linear-gradient(180deg, #f5f7fb 0%, #eef3f9 100%);
      min-height: 100vh;
    }

    .orar-form-shell {
      background: #ffffff;
      border: 1px solid rgba(17, 24, 39, 0.08);
      border-radius: 32px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
      overflow: hidden;
    }

    .orar-form-sidebar {
      background: linear-gradient(180deg, #163a63 0%, #244f81 55%, #2f6a9f 100%);
      color: #f8fafc;
      padding: 2.5rem;
      position: relative;
    }

    .orar-form-sidebar::after {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 55%);
      border-radius: 28px;
      content: "";
      inset: 1.25rem;
      pointer-events: none;
      position: absolute;
    }

    .orar-form-sidebar > * {
      position: relative;
      z-index: 1;
    }

    .orar-form-sidebar h1 {
      line-height: 1.18;
    }

    .orar-form-sidebar p {
      line-height: 1.6;
    }

    .orar-form-kicker,
    .orar-section-kicker {
      color: #8cb7e2;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .orar-side-card {
      backdrop-filter: blur(10px);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 24px;
      padding: 1.25rem;
    }

    .orar-side-card li {
      line-height: 1.55;
    }

    .orar-form-panel {
      padding: 2.5rem;
    }

    .orar-step-badge {
      background: #eef4fb;
      border-radius: 999px;
      color: #2a5788;
      font-size: 0.92rem;
      font-weight: 700;
      padding: 0.65rem 1rem;
      white-space: nowrap;
    }

    .orar-stepper-progress {
      background: #dbe6f4;
      border-radius: 999px;
      height: 0.5rem;
      overflow: hidden;
    }

    .orar-stepper-progress .progress-bar {
      background: linear-gradient(90deg, #2a5788 0%, #4d88c4 100%);
      border-radius: 999px;
      transition: width 0.25s ease;
    }

    .orar-search-input-group {
      align-items: stretch;
      border-radius: 14px;
      overflow: hidden;
    }

    .input-group.orar-search-input-group > .input-group-text {
      background: #f8fbff;
      border-color: #d9e4f0;
      border-radius: 14px 0 0 14px !important;
      color: #5e86b5;
      min-height: 3rem;
      padding-inline: 0.85rem;
    }

    .input-group.orar-search-input-group > .form-control {
      border-color: #d9e4f0;
      border-left: 0;
      border-radius: 0 !important;
      border-right: 0;
      min-height: 3rem;
    }

    .orar-search-input-group .form-control:focus {
      border-color: #7ca8d3;
      box-shadow: none;
    }

    .orar-search-input-group:focus-within {
      border-radius: 14px;
      box-shadow: 0 0 0 0.25rem rgba(42, 87, 136, 0.16);
    }

    .orar-search-input-group:focus-within .input-group-text,
    .orar-search-input-group:focus-within .form-control,
    .orar-search-input-group:focus-within .orar-clear-input-btn {
      border-color: #7ca8d3;
    }

    .orar-clear-input-btn {
      align-items: center;
      border-color: #d9e4f0;
      border-left: 0;
      border-radius: 0 14px 14px 0 !important;
      color: #5b6472;
      display: inline-flex;
      flex: 0 0 38px !important;
      justify-content: center;
      max-width: 38px;
      min-height: 3rem;
      min-width: 38px !important;
      padding: 0 !important;
      width: 38px !important;
    }

    .orar-clear-input-btn .bi {
      font-size: 0.7rem;
      line-height: 1;
    }

    .orar-clear-input-btn:hover,
    .orar-clear-input-btn:focus {
      background: #eef4fb;
      border-color: #7ca8d3;
      color: #2a5788;
    }

    .orar-stepper-items {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .orar-stepper-item {
      align-items: center;
      background: #f8fbff;
      border: 1px solid #d9e4f0;
      border-radius: 20px;
      color: #5b6472;
      display: flex;
      gap: 0.9rem;
      padding: 1rem 1.1rem;
      text-align: left;
      transition: all 0.2s ease;
      width: 100%;
    }

    .orar-stepper-item strong,
    .orar-stepper-item small {
      display: block;
    }

    .orar-stepper-item small {
      color: #7b8794;
      font-size: 0.82rem;
      margin-top: 0.2rem;
    }

    .orar-stepper-item.is-active,
    .orar-stepper-item.is-complete {
      background: #eef4fb;
      border-color: #a9c3de;
      color: #163a63;
    }

    .orar-stepper-circle {
      align-items: center;
      background: #ffffff;
      border: 2px solid #bfd1e3;
      border-radius: 50%;
      color: #2a5788;
      display: inline-flex;
      font-weight: 700;
      height: 2.5rem;
      justify-content: center;
      min-width: 2.5rem;
    }

    .orar-event-link-card {
      align-items: center;
      background: #f8fbff;
      border: 1px solid #d9e4f0;
      border-radius: 20px;
      display: flex;
      gap: 1.5rem;
      justify-content: space-between;
      padding: 1.5rem;
    }

    .orar-stepper-item.is-active .orar-stepper-circle,
    .orar-stepper-item.is-complete .orar-stepper-circle {
      background: #2a5788;
      border-color: #2a5788;
      color: #ffffff;
    }

    .orar-step-panel {
      display: none;
    }

    .orar-step-panel.is-active {
      display: block;
    }

    .orar-option-card {
      align-items: center;
      background: #f8fbff;
      border: 1px solid #d9e4f0;
      border-radius: 18px;
      display: flex;
      gap: 0.75rem;
      min-height: 88px;
      padding: 1rem;
    }

    .orar-option-card .form-check-input {
      float: none;
      margin: 0;
    }

    .orar-option-card .form-check-label {
      color: #22313f;
      font-weight: 600;
    }

    .orar-radio-grid {
      display: grid;
      gap: 0.65rem;
      grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
    }

    .orar-radio-card {
      align-items: center;
      background: #f8fbff;
      border: 1px solid #d9e4f0;
      border-radius: 14px;
      color: #22313f;
      cursor: pointer;
      display: flex;
      font-weight: 600;
      gap: 0.65rem;
      min-height: 3rem;
      padding: 0.75rem 0.95rem;
    }

    .orar-radio-card:has(.form-check-input:checked) {
      background: #eef4fb;
      border-color: #7ca8d3;
      color: #163a63;
    }

    .orar-radio-grid:has(.is-invalid) + .invalid-feedback {
      display: block;
    }

    .form-control,
    .form-select {
      border-radius: 14px;
      min-height: 3rem;
      padding: 0.75rem 0.95rem;
    }

    .form-control:focus,
    .form-select:focus,
    .form-check-input:focus {
      border-color: #7ca8d3;
      box-shadow: 0 0 0 0.25rem rgba(42, 87, 136, 0.16);
    }

    .orar-step-panel > .d-flex .btn {
      border-radius: 999px;
      font-weight: 600;
      min-width: 160px;
      padding-block: 0.8rem;
    }

    .orar-inscricao-page .orar-clear-input-btn {
      border-radius: 0 14px 14px 0 !important;
      min-width: 38px !important;
      padding-block: 0 !important;
    }

    @media (max-width: 991.98px) {
      .orar-form-sidebar,
      .orar-form-panel {
        padding: 2rem;
      }
    }

    @media (max-width: 767.98px) {
      .orar-inscricao-container {
