<% content_for :title, "Nova Senha | ORAR 2026" %>

<%= render "devise/shared/auth_card",
           eyebrow: "Senha",
           title: "Defina uma nova senha",
           description: "Escolha uma nova senha para recuperar o acesso ao painel." do %>
  <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "d-grid gap-3" }) do |f| %>
    <%= f.error_notification %>
    <%= f.input :reset_password_token, as: :hidden %>
    <%= f.full_error :reset_password_token %>

    <%= f.input :password,
                label: "Nova senha",
                required: true,
                autofocus: true,
                hint: (@minimum_password_length.present? ? "Minimo de #{@minimum_password_length} caracteres." : nil),
                input_html: { autocomplete: "new-password", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.input :password_confirmation,
                label: "Confirmar nova senha",
                required: true,
                input_html: { autocomplete: "new-password", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.submit "Alterar senha", class: "btn orar-auth-button fw-semibold" %>
  <% end %>

  <div class="orar-auth-links mt-4 pt-3 border-top">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
