<% content_for :title, "Entrar | ORAR 2026" %>

<%= render "devise/shared/auth_card",
           eyebrow: "Login",
           title: "Acesse sua conta",
           description: "Use seu e-mail e senha cadastrados para entrar no painel." do %>
  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "d-grid gap-3" }) do |f| %>
    <%= f.error_notification %>

    <%= f.input :email,
                label: "E-mail",
                required: false,
                autofocus: true,
                input_html: { autocomplete: "email", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.input :password,
                label: "Senha",
                required: false,
                input_html: { autocomplete: "current-password", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <% if devise_mapping.rememberable? %>
      <%= f.input :remember_me,
                  as: :boolean,
                  label: "Lembrar de mim",
                  wrapper_html: { class: "mb-0" },
                  label_html: { class: "text-secondary" } %>
    <% end %>

    <%= f.submit "Entrar", class: "btn orar-auth-button fw-semibold" %>
  <% end %>

  <div class="orar-auth-links mt-4 pt-3 border-top">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
