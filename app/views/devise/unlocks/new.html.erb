<% content_for :title, "Desbloquear Conta | ORAR 2026" %>

<%= render "devise/shared/auth_card",
           eyebrow: "Desbloqueio",
           title: "Reenviar desbloqueio",
           description: "Informe seu e-mail para receber um novo link de desbloqueio." do %>
  <%= simple_form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "d-grid gap-3" }) do |f| %>
    <%= f.error_notification %>

    <%= f.input :email,
                label: "E-mail",
                required: true,
                autofocus: true,
                input_html: { autocomplete: "email", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.submit "Reenviar desbloqueio", class: "btn orar-auth-button fw-semibold" %>
  <% end %>

  <div class="orar-auth-links mt-4 pt-3 border-top">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
