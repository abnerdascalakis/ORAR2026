<style>
  .orar-auth-page {
    min-height: 100vh;
    background:
      linear-gradient(135deg, rgba(16, 42, 74, 0.86), rgba(46, 95, 149, 0.62)),
      url("<%= image_path('banner.jpg') %>") center/cover no-repeat;
    position: relative;
    overflow: hidden;
  }

  .orar-auth-page::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 18%, rgba(243, 240, 230, 0.16), transparent 24%),
      radial-gradient(circle at 78% 22%, rgba(217, 230, 245, 0.2), transparent 18%),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.06) 0, rgba(255, 255, 255, 0.06) 1px, transparent 1px, transparent 14px),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.04) 0, rgba(255, 255, 255, 0.04) 1px, transparent 1px, transparent 14px);
    pointer-events: none;
  }

  .orar-auth-panel {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .orar-auth-brand {
    color: #f3f0e6;
    max-width: 420px;
  }

  .orar-auth-chip {
    background: rgba(243, 240, 230, 0.14);
    border: 1px solid rgba(243, 240, 230, 0.22);
    color: #f3f0e6;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .orar-auth-card {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(217, 230, 245, 0.7);
    border-radius: 28px;
    box-shadow: 0 30px 70px rgba(15, 33, 56, 0.24);
    backdrop-filter: blur(10px);
  }

  .orar-auth-title {
    color: #163a63;
  }

  .orar-auth-input {
    border: 1px solid rgba(94, 134, 181, 0.25);
    border-radius: 16px;
    min-height: 54px;
  }

  .orar-auth-input:focus {
    border-color: #2a5788;
    box-shadow: 0 0 0 0.25rem rgba(42, 87, 136, 0.15);
  }

  .orar-auth-button {
    background: linear-gradient(135deg, #163a63 0%, #2a5788 100%);
    border: 0;
    border-radius: 16px;
    color: #f3f0e6;
    min-height: 54px;
  }

  .orar-auth-button:hover,
  .orar-auth-button:focus {
    background: linear-gradient(135deg, #112d4d 0%, #244b76 100%);
    color: #f3f0e6;
  }

  .orar-auth-logo {
    background: rgba(255, 255, 255, 0.94);
    border-radius: 22px;
    display: inline-block;
    padding: 0.9rem 1.15rem;
    box-shadow: 0 18px 44px rgba(14, 32, 54, 0.18);
  }

  .orar-auth-copy {
    color: rgba(243, 240, 230, 0.82);
    font-size: 1rem;
    line-height: 1.6;
  }

  .orar-auth-links a {
    color: #2a5788;
    font-weight: 600;
    text-decoration: none;
  }

  .orar-auth-links a:hover,
  .orar-auth-links a:focus {
    color: #163a63;
    text-decoration: underline;
  }

  @media (max-width: 991.98px) {
    .orar-auth-page {
      background-position: center top;
    }

    .orar-auth-panel {
      min-height: auto;
    }

    .orar-auth-brand {
      max-width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 575.98px) {
    .orar-auth-logo {
      display: block;
      width: 100%;
      padding: 0.85rem 1rem;
    }

    .orar-auth-card {
      border-radius: 22px;
    }

    .orar-auth-title {
      font-size: 1.6rem;
    }
  }
</style>

<section class="orar-auth-page">
  <div class="container orar-auth-panel d-flex align-items-center">
    <div class="row align-items-center g-4 g-lg-5 w-100 py-5">
      <div class="col-lg-7">
        <span class="badge rounded-pill orar-auth-chip px-3 py-2 mb-4">Area administrativa</span>
        <div class="orar-auth-brand">
          <div class="orar-auth-logo mb-4">
            <strong class="d-block fs-3" style="color: #163a63;">ORAR 2026</strong>
            <span class="text-secondary">Olimpiada Regional Adventista de Rondonia</span>
          </div>

          <p class="orar-auth-copy mb-0"><%= local_assigns.fetch(:subtitle, "Acesso restrito ao painel administrativo do evento.") %></p>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="orar-auth-card p-4 p-lg-5">
          <div class="mb-4">
            <% if local_assigns[:eyebrow].present? %>
              <p class="text-uppercase fw-semibold mb-2" style="letter-spacing: 0.08em; color: #5e86b5;"><%= local_assigns[:eyebrow] %></p>
            <% end %>
            <h2 class="orar-auth-title fw-bold mb-2"><%= title %></h2>
            <% if local_assigns[:description].present? %>
              <p class="text-secondary mb-0"><%= description %></p>
            <% end %>
          </div>

          <%= yield %>
        </div>
      </div>
    </div>
  </div>
</section>
