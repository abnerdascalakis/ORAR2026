<% content_for :title, "Criar Conta | ORAR 2026" %>

<%= render "devise/shared/auth_card",
           eyebrow: "Cadastro",
           title: "Crie sua conta",
           description: "Preencha seus dados para solicitar acesso ao painel administrativo." do %>
  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "d-grid gap-3" }) do |f| %>
    <%= f.error_notification %>

    <%= f.input :email,
                label: "E-mail",
                required: true,
                autofocus: true,
                input_html: { autocomplete: "email", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.input :password,
                label: "Senha",
                required: true,
                hint: (@minimum_password_length.present? ? "Minimo de #{@minimum_password_length} caracteres." : nil),
                input_html: { autocomplete: "new-password", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.input :password_confirmation,
                label: "Confirmar senha",
                required: true,
                input_html: { autocomplete: "new-password", class: "orar-auth-input px-3" },
                label_html: { class: "fw-semibold text-dark" },
                wrapper_html: { class: "mb-0" } %>

    <%= f.submit "Criar conta", class: "btn orar-auth-button fw-semibold" %>
  <% end %>

  <div class="orar-auth-links mt-4 pt-3 border-top">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
